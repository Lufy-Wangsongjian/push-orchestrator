{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Push Orchestrator Tasks",
  "type": "object",
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "provider", "enabled"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "enabled": { "type": "boolean" },
          "type": {
            "type": "string",
            "enum": ["reminder", "content", "market", "ops", "test"]
          },
          "provider": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "cron": { "type": "string" },
          "channel": { "type": "string" },
          "target": { "type": "string" },
          "timeout_seconds": { "type": "integer" },
          "retry_policy_override": { "type": "object" },
          "notification_policy": { "type": "object" },
          "dedupe": {
            "type": "object",
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["none", "window", "hash", "topic_cooldown", "hash_topic"]
              },
              "window_minutes": { "type": "integer" },
              "topic_key": { "type": "string" },
              "cooldown_days": { "type": "number" }
            }
          },
          "requires_realtime": { "type": "boolean" },
          "source_priority": { "type": "array" },
          "archive_enabled": { "type": "boolean" },
          "archive_category": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "content_kind": { "type": "string" },
          "content_source_type": {
            "type": "string",
            "enum": ["template", "script", "prompt", "api", "rss", "db", "file", "hybrid"]
          },
          "render_strategy": { "type": "string" },
          "dedupe_strategy": {
            "type": "string",
            "enum": ["none", "hash", "topic_cooldown", "hash_topic", "window"]
          },
          "content_handler": { "type": "string" },
          "template_path": { "type": "string" },
          "source_config": { "type": "object" },
          "metadata": { "type": "object" }
        }
      }
    }
  }
}
