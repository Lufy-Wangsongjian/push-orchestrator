{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Push Orchestrator Channels",
  "type": "object",
  "properties": {
    "channels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["telegram", "webhook", "email"] },
          "sendCommand": { "type": "string" },
          "defaultTarget": { "type": "string" },
          "config": { "type": "object" }
        }
      }
    }
  }
}
